# STDF Platform Configuration

ftp:
  host: "ftp.example.com"
  port: 21
  username: "${FTP_USER}"
  password: "${FTP_PASSWORD}"
  base_path: "/"
  patterns:
    - "*.stdf"
    - "*.stdf.gz"
    - "*.std"
    - "*.std.gz"

# Product and Test Type filtering
# - If filters is empty or not specified, all products and test types are fetched
# - Specify product-specific test types as shown below
filters:
  # - product: SCT101A
  #   test_types: [CP]      # Only CP for SCT101A
  # - product: ABC200B
  #   test_types: [CP, FT]  # Both CP and FT for ABC200B

# Exclude patterns — filenames matching any pattern are skipped (fetch and ingest-all).
# Uses fnmatch glob syntax, case-insensitive. Matches against filename only (not full path).
# Examples:
#   - "*EVAL*"      # skip any file containing "EVAL"
#   - "*_test_*"    # skip files with "_test_" in the name
#   - "debug_*"     # skip files starting with "debug_"
exclude:
  # - "*EVAL*"
  # - "*_qual_*"

storage:
  data_dir: "./data"
  database: "./data/stdf.duckdb"
  download_dir: "./downloads"

processing:
  batch_size: 1000
  compression: "zstd"  # gzip より高圧縮・高速展開。DuckDB が読める（Parquet v2.6 / 既定エンコーディング）

# Per-product settings
# gross_die: expected total die per wafer (from mask layout).
#   Dies lost to fab inline failure are never probed; gross die fill entries
#   (bin = gd_fail_bin) are injected at first ingest so yield denominators
#   reflect the full gross die count.
# gd_fail_bin: soft/hard bin assigned to inline-fail (unprobed) fill dies (default 200).
products:
  # SCT101A:
  #   gross_die: 1234
  #   gd_fail_bin: 200

# Report engine (stdf report)
reporting:
  histogram_top_n: 20          # parametric histograms: top-N by fail rate
  always_include_tests: {}     # e.g. {PRODUCT_A: [1234, 5678]} — always plotted
